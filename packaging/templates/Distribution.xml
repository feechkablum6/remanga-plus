<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>ReManga Plus</title>
    <organization>org.remanga</organization>
    <domains enable_localSystem="true"/>
    <options customize="never" require-scripts="true" hostArchitectures="arm64"/>
    <volume-check>
        <allowed-os-versions>
            <os-version min="11.0"/>
        </allowed-os-versions>
    </volume-check>
    <choices-outline>
        <line choice="default">
            <line choice="org.remanga.plus.core"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="org.remanga.plus.core" visible="false">
        <pkg-ref id="org.remanga.plus.core"/>
    </choice>
    <pkg-ref id="org.remanga.plus.core" version="0.3.0" onConclusion="none">core.pkg</pkg-ref>
</installer-gui-script>
