{
  "name": "remanga-reader-enhancer",
  "version": "0.5.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && vite build --config vite.background.config.ts && vite build --config vite.popup.config.ts",
    "check": "tsc --noEmit && tsc -p native-host/tsconfig.json --noEmit",
    "dev": "vite build --watch",
    "native:build": "tsc -p native-host/tsconfig.json",
    "native:install": "tsx native-host/install-macos.ts",
    "pkg:build": "node packaging/scripts/build-pkg.mjs",
    "pkg:test": "node --test packaging/tests/build-pkg.test.mjs packaging/tests/bundle-parser.test.mjs packaging/tests/download-node.test.mjs packaging/tests/postinstall.test.mjs",
    "pkg:windows": "node packaging/scripts/build-installer-windows.mjs",
    "pkg:windows:test": "node --test packaging/tests/host-bat.test.mjs packaging/tests/installer-nsi.test.mjs packaging/tests/download-node-windows.test.mjs packaging/tests/build-installer-windows.test.mjs",
    "version": "node scripts/sync-manifest-version.mjs && git add public/manifest.json",
    "postversion": "npm run build"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.31",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.3.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
